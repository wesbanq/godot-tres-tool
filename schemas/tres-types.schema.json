{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/godot-tres-tool/schemas/tres-types.schema.json",
  "title": "Godot .tres resource JSON",
  "description": "JSON shape produced by ResourceFile.toJSON and accepted by ResourceFile.fromJSON (see src/tres-types.ts). The Serializable interface is TypeScript-only and is not a persisted document shape.",
  "$ref": "#/$defs/ResourceFile",
  "$defs": {
    "ResourceType": {
      "description": "Bracket header kind in a .tres file.",
      "type": "string",
      "enum": ["resource", "sub_resource", "ext_resource", "gd_resource"]
    },
    "ResourceUid": {
      "description": "Godot unique-id reference.",
      "type": "string",
      "pattern": "^uid://"
    },
    "ResourceId": {
      "description": "In-file resource id.",
      "type": "string",
      "pattern": "^id://"
    },
    "ResourceRes": {
      "description": "Project path reference.",
      "type": "string",
      "pattern": "^res://"
    },
    "ResourceTypeModifier": {
      "description": "name=value pair inside a [...] header (e.g. path=, type=, format=).",
      "type": "object",
      "required": ["name", "value"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "ResourceProperty": {
      "description": "One key = value under a resource block. value matches TypeScript any (JSON primitives, arrays, objects, etc.).",
      "type": "object",
      "required": ["name", "value"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": true
      },
      "additionalProperties": false
    },
    "ResourceHeader": {
      "description": "The [type ...] line for a single resource section.",
      "type": "object",
      "required": ["type", "modifiers"],
      "properties": {
        "type": {
          "$ref": "#/$defs/ResourceType"
        },
        "modifiers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ResourceTypeModifier"
          }
        }
      },
      "additionalProperties": false
    },
    "ResourceHeaderGdResource": {
      "description": "Root header: gd_resource with a format modifier (format required by ResourceFile.validate; gd_resource placement also checked by the analyzer).",
      "allOf": [
        {
          "$ref": "#/$defs/ResourceHeader"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "gd_resource"
            },
            "modifiers": {
              "contains": {
                "type": "object",
                "required": ["name", "value"],
                "properties": {
                  "name": {
                    "const": "format"
                  },
                  "value": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "additionalProperties": false
              }
            }
          }
        }
      ]
    },
    "Resource": {
      "description": "Header plus property lines for one sub_resource / ext_resource / inner resource block.",
      "type": "object",
      "required": ["header", "properties"],
      "properties": {
        "header": {
          "$ref": "#/$defs/ResourceHeader"
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ResourceProperty"
          }
        }
      },
      "additionalProperties": false
    },
    "ResourceNotGdResource": {
      "description": "Inner resources must not use gd_resource (enforced by the analyzer).",
      "allOf": [
        {
          "$ref": "#/$defs/Resource"
        },
        {
          "type": "object",
          "properties": {
            "header": {
              "type": "object",
              "properties": {
                "type": {
                  "not": {
                    "const": "gd_resource"
                  }
                }
              }
            }
          }
        }
      ]
    },
    "ResourceFile": {
      "description": "Whole .tres document as JSON: leading gd_resource header plus ordered resource blocks (resources.length >= 1 per validate). Index 0 is any Resource; further entries must not use gd_resource.",
      "type": "object",
      "required": ["header", "resources"],
      "properties": {
        "header": {
          "$ref": "#/$defs/ResourceHeaderGdResource"
        },
        "resources": {
          "type": "array",
          "minItems": 1,
          "prefixItems": [
            {
              "$ref": "#/$defs/Resource"
            }
          ],
          "items": {
            "$ref": "#/$defs/ResourceNotGdResource"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
