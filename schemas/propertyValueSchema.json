        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "pattern": "^res:\\/\\/.*"
        },
        {
          "type": "string",
          "pattern": "^uid:\\/\\/.*"
        },
        {
          "type": "string",
          "pattern": "^id:\\/\\/.*"
        },
        {
          "type": "string",
          "pattern": "^ExtResource\\s*\\("
        },
        {
          "type": "string",
